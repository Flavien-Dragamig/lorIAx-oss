# ============================================================
# LorIAx — Variables d'environnement
# Copier en .env.local pour le développement
# ============================================================
#
# Variables OBLIGATOIRES marquées [REQUIRED]
# Variables optionnelles marquées [OPTIONAL]
#

# ============================================================
# Base de données [REQUIRED]
# ============================================================
# PostgreSQL avec extensions pgvector + pg_trgm
# En Docker Compose, utiliser le hostname du service : postgres
DATABASE_URL=postgresql://loriax:loriax_secret@localhost:5432/loriax

# ============================================================
# Serveur [REQUIRED]
# ============================================================
# Port d'écoute du serveur custom (Next.js + WebSocket)
PORT=3000
# Nombre de reverse proxies de confiance (Traefik, Nginx…) pour IP forwarding
TRUSTED_PROXY_COUNT=1

# ============================================================
# Authentification [REQUIRED]
# ============================================================
# URL publique de l'application (utilisée pour les redirections NextAuth)
NEXTAUTH_URL=http://localhost:3000

# Clé secrète pour signer les JWT / sessions
# Générer avec : openssl rand -base64 32
NEXTAUTH_SECRET=generate-a-random-secret-here
# Généré automatiquement par dev.sh au premier lancement

# Domaine partagé entre sous-domaines pour le cookie de session (ex: .loriax.fr)
# NEXTAUTH_COOKIE_DOMAIN=

# ============================================================
# URLs publiques [REQUIRED en production]
# ============================================================
# URL publique de l'app (utilisée dans les emails, webhooks, QR codes)
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Domaine racine pour le routing multi-org (ex: loriax.fr)
# NEXT_PUBLIC_ROOT_DOMAIN=loriax.fr
# URL du license manager (pour la validation des licences)
# NEXT_PUBLIC_LICENSE_MANAGER_URL=https://license.loriax.fr

# ============================================================
# Communication interne [REQUIRED en production multi-service]
# ============================================================
# Secret partagé entre loriax-app et loriax-license-manager
# Générer avec : openssl rand -hex 32
INTERNAL_API_SECRET=generate-a-random-hex-32-here
# URL WebSocket interne (utilisée par le serveur pour les connexions Hocuspocus)
# WS_URL=ws://localhost:3000

# ============================================================
# Chiffrement [REQUIRED]
# ============================================================
# Clé 32 octets base64 pour chiffrer les clés API des providers IA en BDD
# Générer avec : openssl rand -base64 32
ENCRYPTION_KEY=generate-a-32-byte-base64-key-here
# Généré automatiquement par dev.sh au premier lancement

# ============================================================
# Stockage objet S3-compatible — Garage [REQUIRED]
# ============================================================
# Endpoint du service S3 (Garage, MinIO, AWS S3, etc.)
S3_ENDPOINT=localhost
S3_PORT=3900
# Format Garage : GK + 24 hex (ex: GK + node -e "require('crypto').randomBytes(12).toString('hex')")
S3_ACCESS_KEY=GK6c6f72696178000000000000
# Format Garage : 64 hex (ex: node -e "require('crypto').randomBytes(32).toString('hex')")
S3_SECRET_KEY=6c6f726961787365637265740000000000000000000000000000000000000000
S3_BUCKET=loriax-files
S3_REGION=garage
# Activer TLS pour le stockage (true en production derrière un reverse proxy HTTPS)
S3_USE_SSL=false

# ============================================================
# Stockage documents Markdown [OPTIONAL]
# ============================================================
# Chemin vers les workspaces git (relatif ou absolu)
# Par défaut : ./workspaces
WORKSPACES_PATH=./workspaces

# ============================================================
# IA — Providers [OPTIONAL]
# ============================================================
# Configurer au moins un provider pour le chat IA et le résumé

# Anthropic (Claude)
ANTHROPIC_API_KEY=

# OpenAI
OPENAI_API_KEY=

# Mistral AI
MISTRAL_API_KEY=

# Ollama (modèles locaux) [AUTO — démarré par dev:full]
OLLAMA_BASE_URL=http://localhost:11434

# Provider et modèle par défaut : claude | openai | ollama | mistral
DEFAULT_AI_PROVIDER=ollama
DEFAULT_AI_MODEL=gemma4:e4b

# ============================================================
# IA — Embeddings (recherche sémantique) [OPTIONAL]
# ============================================================
# Provider : openai | ollama
EMBEDDING_PROVIDER=openai
# Modèle d'embedding
EMBEDDING_MODEL=text-embedding-3-small
# Dimensions du vecteur (doit correspondre au modèle)
EMBEDDING_DIMENSIONS=1536

# ============================================================
# Observabilité [OPTIONAL]
# ============================================================
# Niveau de log : error | warn | info | debug
LOG_LEVEL=info

# ============================================================
# Sécurité — Tâches planifiées [OPTIONAL]
# ============================================================
# Secret pour authentifier les appels cron (header Authorization: Bearer <secret>)
# Générer avec : openssl rand -hex 32
# CRON_SECRET=

# ============================================================
# Médias — APIs externes [OPTIONAL]
# ============================================================
# Unsplash (photos libres de droits dans l'éditeur)
# UNSPLASH_ACCESS_KEY=
# Pexels (photos libres de droits dans l'éditeur)
# PEXELS_API_KEY=

# ============================================================
# CalDAV — Calendrier [OPTIONAL]
# ============================================================
# Activer l'intégration CalDAV
CALDAV_ENABLED=false
# URL du serveur CalDAV (ex: Radicale, Nextcloud, Baikal)
# CALDAV_BASE_URL=http://localhost:5232

# ============================================================
# Email — SMTP [OPTIONAL]
# ============================================================
# Configuré via l'interface admin (Système > Email)
# Les paramètres SMTP sont stockés en BDD (table system_settings)
# Pas de variables d'env nécessaires — tout se fait via l'admin

# ============================================================
# Routage cartographique [OPTIONAL]
# ============================================================
# URL de l'API OSRM pour le calcul d'itinéraires
# Par défaut : https://router.project-osrm.org (API publique gratuite)
# Pour une instance privée Docker : https://github.com/Project-OSRM/osrm-backend
# ROUTING_API_URL=https://router.project-osrm.org

# ============================================================
# LiveKit — Visioconférence [OPTIONAL]
# ============================================================
# Activer l'intégration LiveKit
LIVEKIT_ENABLED=false
# URL du serveur LiveKit (WebSocket)
LIVEKIT_URL=ws://localhost:7880
# Clé API LiveKit (générée par le serveur LiveKit)
# LIVEKIT_API_KEY=devkey
# Secret API LiveKit (généré par le serveur LiveKit)
# LIVEKIT_API_SECRET=devsecret
# Chemin du volume d'enregistrement audio (Egress)
# LIVEKIT_EGRESS_PATH=/recordings

# ============================================================
# Whisper — Transcription audio [OPTIONAL]
# ============================================================
# Activer la transcription automatique post-réunion (requiert LIVEKIT_ENABLED)
# Whisper démarre automatiquement avec LiveKit (plus de profil optionnel)
WHISPER_ENABLED=true
# URL du service Whisper (faster-whisper-server ou whisper-asr-webservice)
WHISPER_API_URL=http://localhost:9000
# Modèle Whisper : tiny, base, small, medium, large
WHISPER_MODEL=base
# Langue par défaut pour la transcription
WHISPER_LANGUAGE=fr
# Activer la diarization (identification du locuteur) — requiert ASR_ENGINE=whisperx + HF_TOKEN
WHISPER_DIARIZE=false
# Nombre min/max de locuteurs (aide le modèle de diarization)
# WHISPER_MIN_SPEAKERS=2
# WHISPER_MAX_SPEAKERS=6

# ============================================================
# Voxtral — Transcription Mistral [démarre avec LiveKit]
# ============================================================
# Moteur STT alternatif à Whisper, auto-hébergé via Docker
# Démarre automatiquement avec LiveKit (comme Whisper)
# Le modèle se télécharge automatiquement au premier démarrage (~4 Go)
# ============================================================
# Voxtral Realtime — STT Mistral via vLLM [OPTIONAL — GPU requis]
# ============================================================
# Modèle : mistralai/Voxtral-Mini-4B-Realtime-2602 (Apache-2.0)
# Requiert un GPU NVIDIA >= 16 Go VRAM (BF16)
# Activer : profil Docker "voxtral" + VOXTRAL_ENABLED=true
VOXTRAL_ENABLED=false
VOXTRAL_API_URL=http://localhost:9001
VOXTRAL_MODEL=mistralai/Voxtral-Mini-4B-Realtime-2602
VOXTRAL_LANGUAGE=fr
# Moteur de transcription actif : whisper (CPU) ou voxtral (GPU)
TRANSCRIPTION_ENGINE=whisper

# ============================================================
# PENPOT — Tableau blanc et prototypage [OPTIONAL]
# ============================================================
# Penpot auto-hébergé via docker-compose.penpot.yml
# Si vide, les commandes /tableau-blanc et /prototype sont masquées
# Les blocs existants restent consultables en lecture seule (miniatures)

# Activer le lancement automatique de Penpot avec dev:full
PENPOT_ENABLED=false
# PENPOT_INTERNAL_URL=http://penpot-backend:6060
# PENPOT_FRONTEND_URL=http://penpot-frontend:8080 # Frontend Penpot (iframe workspace)
# PENPOT_SECRET_KEY=                              # openssl rand -hex 32

# ============================================================
# LDAP / SSO [OPTIONAL]
# ============================================================
# Configuré via l'interface admin (Système > LDAP)
# Les paramètres LDAP sont stockés en BDD (table system_settings)
# Pas de variables d'env nécessaires — tout se fait via l'admin


# ============================================================
# Redis — Rate limiting multi-instance [OPTIONAL]
# ============================================================
# Si défini, le rate limiting est partagé entre instances (Docker, serverless, etc.)
# Format : redis://[:password@]host[:port][/db]  ou  rediss:// pour TLS
# Si absent, fallback sur le backend in-memory (développement ou instance unique)
# REDIS_URL=redis://localhost:6379

# ============================================================
# LICENCE [OPTIONAL]
# ============================================================
# Clé publique RSA pour valider les licences (base64 ou PEM)
# LICENSE_PUBLIC_KEY=

# Clé privée RSA — génération manuelle de licences (super_admin uniquement)
# À ne configurer que sur les instances autorisées à émettre des licences
# LICENSE_PRIVATE_KEY=

# URL du service license manager (pour les instances auto-hébergées)
# LICENSE_MANAGER_URL=https://licences.loriax.fr
